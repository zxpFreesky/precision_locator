# LLM Provider: openai / zhipu / minimax / qwen / deepseek / moonshot
LLM_PROVIDER=openai

# LLM Model (leave empty to use provider default)
LLM_MODEL=

# LLM Temperature (0.0 = deterministic)
LLM_TEMPERATURE=0.0

# API Keys (set at least one matching your LLM_PROVIDER)
OPENAI_API_KEY=sk-xxx
# ZHIPU_API_KEY=xxx
# MINIMAX_API_KEY=xxx
# DASHSCOPE_API_KEY=xxx
# DEEPSEEK_API_KEY=xxx
# MOONSHOT_API_KEY=xxx

# Vision Model (optional, defaults to LLM_PROVIDER)
# VISION_LLM_PROVIDER=openai
# VISION_MODEL=gpt-4o

# Browser Settings
HEADLESS=false
# VIEWPORT=1920x1080
# LOCALE=zh-CN
